{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 600,
      "width": 800
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "BarcodeInput"
        },
        "position": {
          "height": 40,
          "width": 360,
          "x": 10,
          "y": 10
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "session.custom.BarCode"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "placeholder": "Enter BarCode",
          "text": ""
        },
        "type": "ia.input.text-field"
      },
      {
        "meta": {
          "name": "RunReportButton"
        },
        "position": {
          "height": 40,
          "width": 160,
          "x": 380,
          "y": 10
        },
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "self.session.custom.BarCode = self.getSibling('BarcodeInput').props.text\nsystem.perspective.printReport('New Report', {'BarCode': self.session.custom.BarCode})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "props": {
          "style": {
            "backgroundColor": "#008000",
            "color": "#ffffff"
          },
          "text": "Run New Report"
        },
        "type": "ia.input.button"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.coord"
  }
}

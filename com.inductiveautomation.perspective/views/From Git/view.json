{
  "custom": {},
  "params": {},
  "props": {
    "defaultSize": {
      "height": 600
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "BarcodeInput"
        },
        "position": {
          "height": 40,
          "width": 360,
          "x": 10,
          "y": 10
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "bidirectional": true,
                "fallbackDelay": 2.5,
                "mode": "direct",
                "tagPath": "[default]QR_Inout"
              },
              "type": "tag"
            }
          }
        },
        "props": {
          "placeholder": "Enter BarCode"
        },
        "type": "ia.input.text-field"
      },
      {
        "events": {
          "component": {
            "onActionPerformed": {
              "config": {
                "script": "self.session.custom.BarCode \u003d self.getSibling(\u0027BarcodeInput\u0027).props.text\nsystem.perspective.printReport(\u0027New Report\u0027, {\u0027BarCode\u0027: self.session.custom.BarCode})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "RunReportButton"
        },
        "position": {
          "height": 40,
          "width": 160,
          "x": 380,
          "y": 10
        },
        "props": {
          "style": {
            "backgroundColor": "#008000",
            "color": "#ffffff"
          },
          "text": "Run New Report"
        },
        "type": "ia.input.button"
      },
      {
        "meta": {
          "name": "Barcode"
        },
        "position": {
          "height": 175,
          "width": 200,
          "x": 83,
          "y": 119
        },
        "propConfig": {
          "props.source": {
            "binding": {
              "config": {
                "expression": "if(isNull({[default]QR_Inout}), '', concat('https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=', urlEncode({[default]QR_Inout})))"
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "fit": {
            "mode": "contain"
          }
        },
        "type": "ia.display.image"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.coord"
  }
}
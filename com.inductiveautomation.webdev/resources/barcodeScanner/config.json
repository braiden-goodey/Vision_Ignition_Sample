  "resource-type": "text-resource",
  "content-type": "text/html",
  "text": "<!doctype html>\r\n<html>\r\n<head>\r\n  <meta charset=\"utf-8\" />\r\n  <meta name=\"viewport\" content=\"width=device-width,initial-scale=1\" />\r\n  <title>Barcode Scanner</title>\r\n  <style>\r\n    body {\r\n      margin: 0;\r\n      font-family: sans-serif;\r\n      background: #111;\r\n      color: white;\r\n    }\r\n\r\n    #wrap {\r\n      display: grid;\r\n      gap: 12px;\r\n      padding: 12px;\r\n    }\r\n\r\n    button {\r\n      width: fit-content;\r\n      padding: 10px 16px;\r\n      font-size: 1rem;\r\n      border: 0;\r\n      border-radius: 8px;\r\n      cursor: pointer;\r\n    }\r\n\r\n    video {\r\n      width: 100%;\r\n      max-width: 720px;\r\n      border-radius: 12px;\r\n      background: #000;\r\n    }\r\n\r\n    #result {\r\n      font-size: 1.2rem;\r\n      padding: 8px 0;\r\n      word-break: break-word;\r\n    }\r\n\r\n    canvas {\r\n      display: none;\r\n    }\r\n\r\n    img {\r\n      width: 100%;\r\n      max-width: 720px;\r\n      border-radius: 12px;\r\n      background: #000;\r\n    }\r\n  </style>\r\n</head>\r\n<body>\r\n  <div id=\"wrap\">\r\n    <h2>Scan a barcode</h2>\r\n\r\n    <button id=\"toggleBtn\">Start Camera</button>\r\n    <button id=\"captureBtn\">Capture Photo</button>\r\n\r\n    <video id=\"video\" autoplay muted playsinline></video>\r\n\r\n    <canvas id=\"canvas\"></canvas>\r\n    <img id=\"photo\" alt=\"Captured photo preview\" />\r\n\r\n    <div id=\"result\">Camera stopped.</div>\r\n  </div>\r\n\r\n  <script type=\"module\">\r\n    import { BrowserMultiFormatReader } from \"https://cdn.jsdelivr.net/npm/@zxing/browser@latest/+esm\";\r\n\r\n    const toggleBtn = document.getElementById(\"toggleBtn\");\r\n    const captureBtn = document.getElementById(\"captureBtn\");\r\n    const videoEl = document.getElementById(\"video\");\r\n    const resultEl = document.getElementById(\"result\");\r\n    const canvas = document.getElementById(\"canvas\");\r\n    const photo = document.getElementById(\"photo\");\r\n\r\n    const codeReader = new BrowserMultiFormatReader();\r\n\r\n    let cameraRunning = false;\r\n    let controls = null;\r\n    let lastScan = \"\";\r\n\r\n    async function startCamera() {\r\n      try {\r\n        const devices = await navigator.mediaDevices.enumerateDevices();\r\n        const videoDevices = devices.filter(d => d.kind === \"videoinput\");\r\n        const deviceId = videoDevices.length ? videoDevices[0].deviceId : undefined;\r\n\r\n        cameraRunning = true;\r\n        toggleBtn.textContent = \"Stop Camera\";\r\n        resultEl.textContent = \"Camera ready. Aim at a barcode.\";\r\n\r\n        controls = await codeReader.decodeFromVideoDevice(deviceId, videoEl, (result, err) => {\r\n          if (result) {\r\n            const text = result.getText().trim();\r\n\r\n            if (text === lastScan) {\r\n              return;\r\n            }\r\n            lastScan = text;\r\n\r\n            resultEl.textContent = \"Scanned: \" + text;\r\n\r\n            fetch(\"/system/webdev/Vision_Playground/ScannedData\", {\r\n              method: \"POST\",\r\n              headers: { \"Content-Type\": \"application/json\" },\r\n              body: JSON.stringify({ barcode: text })\r\n            });\r\n\r\n            if (text.startsWith(\"http://\") || text.startsWith(\"https://\")) {\r\n              const newTab = window.open(text, \"_blank\");\r\n              if (!newTab) {\r\n                resultEl.textContent = \"Popup blocked. Allow popups for this site.\";\r\n              }\r\n            }\r\n          }\r\n        });\r\n      } catch (e) {\r\n        cameraRunning = false;\r\n        toggleBtn.textContent = \"Start Camera\";\r\n        resultEl.textContent = \"Camera error: \" + e.message;\r\n      }\r\n    }\r\n\r\n    function stopCamera() {\r\n      if (controls) {\r\n        controls.stop();\r\n        controls = null;\r\n      }\r\n\r\n      videoEl.srcObject = null;\r\n      cameraRunning = false;\r\n      toggleBtn.textContent = \"Start Camera\";\r\n      resultEl.textContent = \"Camera stopped.\";\r\n    }\r\n\r\n    captureBtn.addEventListener(\"click\", () => {\r\n      if (!cameraRunning || !videoEl.videoWidth || !videoEl.videoHeight) {\r\n        resultEl.textContent = \"Start the camera first.\";\r\n        return;\r\n      }\r\n\r\n      const ctx = canvas.getContext(\"2d\");\r\n      canvas.width = videoEl.videoWidth;\r\n      canvas.height = videoEl.videoHeight;\r\n\r\n      ctx.drawImage(videoEl, 0, 0, canvas.width, canvas.height);\r\n\r\n      const imageData = canvas.toDataURL(\"image/jpeg\", 0.85);\r\n      photo.src = imageData;\r\n\r\n      fetch(\"/system/webdev/Vision_Playground/SavePhoto\", {\r\n        method: \"POST\",\r\n        headers: { \"Content-Type\": \"application/json\" },\r\n        body: JSON.stringify({\r\n          imageData: imageData,\r\n          barcode: lastScan\r\n        })\r\n      })\r\n        .then(async r => {\r\n          const body = await r.text();\r\n          resultEl.textContent = \"Photo saved: \" + r.status + \" \" + body;\r\n        })\r\n        .catch(err => {\r\n          resultEl.textContent = \"Save failed: \" + err;\r\n        });\r\n    });\r\n\r\n    toggleBtn.addEventListener(\"click\", () => {\r\n      if (cameraRunning) {\r\n        stopCamera();\r\n      } else {\r\n        startCamera();\r\n      }\r\n    });\r\n  </script>\r\n</body>\r\n</html>"
}